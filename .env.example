NODE_ENV=development
PORT=3337
DATABASE_URL="postgresql://user:password@localhost:5432/cidade_ativa_db"
JWT_PUBLIC_KEY="<base64-encoded-RS256-public-key>"
JWT_PRIVATE_KEY="<base64-encoded-RS256-private-key>"
OPEN_AI_API_KEY="<your-openai-api-key>"
OPEN_AI_MODEL="gpt-5.5"

# Firebase service account (server-side image uploads to Cloud Storage)
FIREBASE_PROJECT_ID="<your-firebase-project-id>"
FIREBASE_CLIENT_EMAIL="<service-account>@<project>.iam.gserviceaccount.com"
# Keep the PEM on a single line, escaping line breaks as \n
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET="<your-project>.appspot.com"
