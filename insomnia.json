  "resources": [
    {
      "_id": "wrk_cidadeativa",
      "_type": "workspace",
      "name": "Cidade Ativa API",
      "description": "Back-end REST API for the civic urban solicitations platform. City is the tenant: the JWT returned by /authenticate encodes the user's cityId. A middleware reads it from the Bearer token, so listings are auto-scoped to that city and creates are stamped with it — no cityId is sent in request bodies. Flow: Register -> Authenticate -> paste the returned token into the Base environment 'token' variable."
    },
    {
      "_id": "env_base",
      "_type": "environment",
      "parentId": "wrk_cidadeativa",
      "name": "Base",
      "data": {
        "base_url": "http://localhost:3337",
        "token": ""
      }
    },

