generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SolicitationStatus {
  waiting_approval
  not_resolved
  in_progress
  resolved
  unconsidered
}

enum CoolActionCategory {
  LIMPEZA_URBANA
  MEIO_AMBIENTE
  EDUCACAO
  BEM_ESTAR_ANIMAL
  ZELADORIA
  SEGURANCA_COMUNITARIA
  ENGAJAMENTO_COMUNITARIO
}

enum PollStatus {
  active
  inactive
  finished
}

model Log {
  id                  String    @id @default(uuid())
  userId              String
  userName            String
  email               String
  activityDescription String
  createdAt           DateTime  @default(now())
  deletedAt           DateTime?
}

model User {
  id              String           @id @default(uuid())
  name            String
  email           String           @unique
  passwordHash    String
  isCouncilman    Boolean          @default(false)
  isAdmin         Boolean          @default(false)
  address         String
  neighborhood    String
  city            String
  uf              String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime?        @updatedAt
  deletedAt       DateTime?
  solicitations   Solicitation[]
  doneCoolActions DoneCoolAction[]
  votes           Vote[]
}

model SolicitationType {
  id            String         @id @default(uuid())
  description   String         @unique
  deletedAt     DateTime?
  solicitations Solicitation[]
}

model Solicitation {
  id                 String             @id @default(uuid())
  protocolNumber     Int                @default(autoincrement()) @unique
  title              String
  description        String
  neighborhood       String
  city               String
  uf                 String
  street             String
  requestingUserId   String
  solicitationTypeId String
  status             SolicitationStatus @default(not_resolved)
  unsolvedImageUrls  Json               @default("[]")
  solvedImageUrls    Json?
  solvedDate         DateTime?
  solvedCommentary   String?
  solvedUserId       String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime?          @updatedAt
  deletedAt          DateTime?
  requestingUser     User               @relation(fields: [requestingUserId], references: [id])
  solicitationType   SolicitationType   @relation(fields: [solicitationTypeId], references: [id])
}

model CoolAction {
  id              String             @id @default(uuid())
  title           String
  category        CoolActionCategory
  points          Int
  createdAt       DateTime           @default(now())
  deletedAt       DateTime?
  doneCoolActions DoneCoolAction[]
}

model DoneCoolAction {
  id             String     @id @default(uuid())
  userId         String
  description    String
  neighborhood   String
  street         String
  actionPhotoURL String
  coolActionId   String
  createdAt      DateTime   @default(now())
  deletedAt      DateTime?
  user           User       @relation(fields: [userId], references: [id])
  coolAction     CoolAction @relation(fields: [coolActionId], references: [id])
}

model PublicPhone {
  id              String @id @default(uuid())
  institutionName String
  phone           String @unique
}

model Neighborhood {
  id       String @id @default(uuid())
  name     String
  cityName String
}

model Poll {
  id           String     @id @default(uuid())
  title        String
  description  String
  pollCoverUrl String
  startedAt    DateTime?
  finishedAt   DateTime?
  status       PollStatus @default(inactive)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime?  @updatedAt
  deletedAt    DateTime?
  votes        Vote[]
}

model Vote {
  id               String       @id @default(uuid())
  title            String
  description      String
  pollId           String
  userId           String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime?    @updatedAt
  deletedAt        DateTime?
  poll             Poll         @relation(fields: [pollId], references: [id])
  user             User         @relation(fields: [userId], references: [id])
  availableOptions VoteOption[]
}

model VoteOption {
  id         String    @id @default(uuid())
  optionText String
  voteId     String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime? @updatedAt
  deletedAt  DateTime?
  vote       Vote      @relation(fields: [voteId], references: [id])
}

